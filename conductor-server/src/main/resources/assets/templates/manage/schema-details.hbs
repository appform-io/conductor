{{#partial "content"}}
    {{#with schema}}
        <section>
            <div class="row text-center justify-content-center">
                <div class="col-auto"><h4>Details for Schema {{name}}</h4></div>
            </div>
            <div class="row justify-content-center">
                <div class="col-12">
                    <form method="post" action="/manage/schema/update/{{id}}">
                        <div class="row g-3 m-2">
                            <div class="col-3 text-end">
                                <label for="field-name" class="col-form-label fw-bold">Name</label>
                            </div>
                            <div class="col-6">
                                <input type="text" id="field-name" name="name"
                                       class="form-control border border-dark bg-light"
                                       maxlength="45" placeholder="Schema Name" value="{{name}}" disabled>
                            </div>
                        </div>
                        <div class="row g-3 m-2">
                            <div class="col-3 text-end">
                                <label for="fieldDescription" class="col-form-label fw-bold">Description</label>
                            </div>
                            <div class="col-6">
                            <textarea id="fieldDescription" name="description"
                                      class="form-control border border-dark bg-light"
                                      placeholder="A description for the schema">{{description}}</textarea>
                            </div>
                        </div>
                        <div class="row g-3 justify-content-center m-2">
                            <div class="col-auto">
                                <button type="submit" class="btn btn-outline-primary mb-3">Save</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
            <div class="row p-2">
                <div class="col">
                    <div class="row mb-1">
                        <div class="col-sm-10">
                            <h5>Fields</h5>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12">
                            <table class="table table-bordered">
                                <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Display Name</th>
                                    <th>Description</th>
                                    <th>Type</th>
                                    <th>Required</th>
                                    <th>Multiple Allowed</th>
                                    <th>Created</th>
                                    <th>Last Updated</th>
                                    <th></th>
                                </tr>
                                </thead>
                                <tbody>
                                {{#each fields}}
                                    <tr>
                                        <td>{{name}}</td>
                                        <td>{{displayName}}</td>
                                        <td>{{description}}</td>
                                        <td>{{readable type}}</td>
                                        <td>{{#if required eq true}}Yes{{else}}No{{/if}}</td>
                                        <td>{{#if allowMultiple eq true}}Yes{{else}}No{{/if}}</td>
                                        <td>{{created}}</td>
                                        <td>{{updated}}</td>
                                        <td>
                                            <form class="confirmed-form" method="post"
                                                  action="/manage/schema/{{../id}}/fields/delete/{{id}}"
                                                  data-cnf-title="Deleting schema field {{name}}"
                                                  data-cnf-text="Are you sure you want to delete this field?">
                                                <button type="submit" class="btn btn-link p-0 text-danger"><i
                                                        class="bi bi-trash"></i></button>
                                            </form>
                                        </td>
                                    </tr>
                                {{/each}}
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-sm-12 col-md-6 border border-dark">
                            <form method="post" action="/manage/schema/{{id}}/fields/add">
                                <div class="row g-3 m-2">
                                    <div class="col-2 text-end">
                                        <label for="fieldName" class="col-form-label fw-bold">Name</label>
                                    </div>
                                    <div class="col-10">
                                        <input type="text" id="fieldName" name="fieldName"
                                               class="form-control border border-dark bg-light"
                                               maxlength="45" placeholder="Field Name" required>
                                    </div>
                                </div>
                                <div class="row g-3 m-2">
                                    <div class="col-2 text-end">
                                        <label for="fieldDescription"
                                               class="col-form-label fw-bold">Description</label>
                                    </div>
                                    <div class="col-10">
                                                <textarea id="description" name="fieldDescription"
                                                          class="form-control border border-dark bg-light"
                                                          placeholder="A description for the field"></textarea>
                                    </div>
                                </div>
                                <div class="row g-3 m-2">
                                    <div class="col-2 text-end">
                                        <label for="fieldType"
                                               class="col-form-label fw-bold">Type</label>
                                    </div>
                                    <div class="col-10">
                                        <select class="form-control  border border-dark bg-light field-type"
                                                id="fieldType" name="fieldType" required>
                                            <option value="" disabled selected>Select data type</option>
                                            <option value="STRING">String</option>
                                            <option value="NUMBER">Number</option>
                                            <option value="CHOICE">Choice</option>
                                            <option value="BOOLEAN">Boolean</option>
                                            <option value="LOCATION">Location</option>
                                            <option value="DATE">Date</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="row g-3 m-2">
                                    <div class="col-2 text-end">
                                        <label for="fieldRequired"
                                               class="form-check-label fw-bold">Required</label>
                                    </div>
                                    <div class="col-10">
                                        <div class="form-check form-switch">
                                            <input id="fieldRequired" name="fieldRequired"
                                                   class="form-check-input border border-dark"
                                                   type="checkbox" role="switch" value="true">
                                        </div>
                                    </div>
                                </div>
                                <div class="row g-3 m-2  field-extra string-meta d-none">
                                    <div class="col-2 text-end">
                                        <label for="fieldStringMaxLength"
                                               class="col-form-label fw-bold">Max Length</label>
                                    </div>
                                    <div class="col-10 pt-4">
                                        <input type="range"
                                               id="fieldStringMaxLength" name="fieldStringMaxLength"
                                               class="form-range pt-2" min="1" max="255" step="1" value="50"
                                               style="width: 90%"
                                               oninput="this.nextElementSibling.value = this.value">
                                        <output class="ms-2">50</output>
                                    </div>
                                </div>
                                <div class="row g-3 m-2  field-extra string-meta d-none">
                                    <div class="col-2 text-end">
                                        <label for="fieldStringRegex"
                                               class="col-form-label fw-bold">Regex</label>
                                    </div>
                                    <div class="col-10">
                                        <input type="text"
                                               id="fieldStringRegex" name="fieldStringRegex"
                                               class="form-control border border-dark bg-light"
                                               placeholder="Regular expression to be matched">
                                    </div>
                                </div>
                                <div class="row g-3 m-2  field-extra choice-meta d-none">
                                    <div class="col-2 text-end">
                                        <label for="fieldStringMaxLength"
                                               class="col-form-label fw-bold">Choices</label>
                                    </div>
                                    <div class="col-10">
                                        <input type="text"
                                               id="fieldChoiceChoices" name="fieldChoiceChoices"
                                               class="form-control border border-dark bg-light"
                                               placeholder="Comma separated list of choices">
                                    </div>
                                </div>
                                <div class="row g-3 m-2 field-extra choice-meta d-none">
                                    <div class="col-2 text-end">
                                        <label for="fieldChoiceMulti"
                                               class="form-check-label fw-bold">Multi</label>
                                    </div>
                                    <div class="col-10">
                                        <div class="form-check form-switch">
                                            <input id="fieldChoiceMulti" name="fieldChoiceMulti"
                                                   class="form-check-input border border-dark"
                                                   type="checkbox" role="switch" value="true">
                                        </div>
                                    </div>
                                </div>
                                <div class="row g-3 m-2  field-extra number-meta d-none">
                                    <div class="col-2 text-end">
                                        <label class="col-form-label fw-bold">Range</label>
                                    </div>
                                    <div class="col-5">
                                        <input type="number"
                                               id="fieldNumberMin" name="fieldNumberMin"
                                               class="form-control border border-dark bg-light"
                                               placeholder="Min">
                                    </div>
                                    <div class="col-5">
                                        <input type="number"
                                               id="fieldNumberMax" name="fieldNumberMax"
                                               class="form-control border border-dark bg-light"
                                               placeholder="Max">
                                    </div>
                                </div>
                                <div class="row g-3 justify-content-center m-2">
                                    <div class="col-auto">
                                        <button type="submit" class="btn btn-outline-primary mb-3">Save</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

        </section>
    {{/with}}
{{/partial}}


{{#partial "page_js"}}
    $('#fieldType').change(function() {
    const type = $(this).val().toLowerCase();
    $('.field-extra').each(function() {
    $(this).addClass('d-none')
    });

    $('.' + type + '-meta').each(function() {
    $(this).removeClass('d-none')
    });
    });
{{/partial}}
{{> common/base}}