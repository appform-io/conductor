{{#partial "content"}}
    {{#with workflow}}
        <section>
            <div class="row text-center justify-content-center">
                <div class="col-auto"><h2>Details for Workflow {{displayName}}</h2></div>
            </div>
            <div class="row justify-content-center">
                <div class="col-12">
                    <form method="post" action="/manage/workflow/{{id}}" id="workflow-update">
                        <div class="row g-3 m-2">
                            <div class="col-3 text-end">
                                <label for="name" class="col-form-label fw-bold">Name</label>
                            </div>
                            <div class="col-6 p-2">
                                {{displayName}}
                            </div>
                        </div>
                        <div class="row g-3 m-2">
                            <div class="col-3 text-end">
                                <label for="description" class="col-form-label fw-bold">Description</label>
                            </div>
                            <div class="col-6">
                            <textarea id="description" name="description"
                                      class="form-control border border-dark bg-light"
                                      placeholder="A description for the workflow"
                                      maxlength="255">{{description}}</textarea>
                            </div>
                        </div>
                        <div class="row g-3 m-2">
                            <div class="col-3 text-end">
                                <label for="schemaId" class="col-form-label fw-bold">Ticket Schema</label>
                            </div>
                            <div class="col-6">
                                {{../schema/name}}
                            </div>
                        </div>
                        <div class="row g-3 m-2">
                            <div class="col-3 text-end">
                                <label for="titleTemplate" class="col-form-label fw-bold">Title Template</label>
                            </div>
                            <div class="col-6">
                                {{#with titleTemplate}}
                                    <textarea id="titleTemplate" name="titleTemplate"
                                              class="form-control border border-dark bg-light"
                                              placeholder="Handlebars template to extract ticket title from raw payload" required>{{template}}</textarea>
                                {{/with}}
                            </div>
                        </div>
                        <div class="row g-3 m-2">
                            <div class="col-3 text-end">
                                <label for="descriptionTemplate" class="col-form-label fw-bold">Description Template</label>
                            </div>
                            <div class="col-6">
                                {{#with descriptionTemplate}}
                                    <textarea id="descriptionTemplate" name="descriptionTemplate"
                                              class="form-control border border-dark bg-light"
                                              placeholder="Handlebars template to extract ticket description from raw payload">{{template}}</textarea>
                                {{/with}}
                            </div>
                        </div>
                        <div class="row g-3 m-2">
                            <div class="col-3 text-end">
                                <label for="subjectTemplate" class="col-form-label fw-bold">Subject ID Template</label>
                            </div>
                            <div class="col-6">
                            {{#with subjectIdTemplate}}
                                <textarea id="subjectTemplate" name="subjectTemplate"
                                          class="form-control border border-dark bg-light"
                                          placeholder="Handlebars template to extract subject from raw payload">{{template}}</textarea>
                            {{/with}}
                            </div>
                        </div>
                        <div class="row g-3 justify-content-center m-2">
                            <div class="col-auto">
                                <button type="submit" class="btn btn-outline-primary mb-3">Save</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </section>
        <section>
            <div class="row">
                <div class="col">
                    <h3>State Machine</h3>
                </div>
            </div>
            <div class="row">
                <div class="col">
                    <form method="post" action="/manage/workflow/{{id}}/states/add">
                        <div class="row g-3 m2">
                            <div class="col-3">
                                <input type="text" id="stateName" name="stateName" class="form-control border border-dark bg-light"
                                       maxlength="45" placeholder="State Name" required>
                            </div>
                            <div class="col-7">
                                <input type="text" id="stateDescription" name="stateDescription" class="form-control border border-dark bg-light"
                                       maxlength="255" placeholder="Description">
                            </div>
                            <div class="col-1 form-check form-switch pt-2">
                                <input class="form-check-input  border border-dark" type="checkbox" role="switch"
                                       id="stateIsTerminal" name="stateIsTerminal" value="true">
                                <label class="form-check-label" for="stateIsTerminal">Terminal</label>
                            </div>
                            <div class="col d-flex justify-content-end">
                                <button type="submit" class="btn btn-outline-success btn-sm"><i class="bi bi-save"></i></button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
            <div class="row mt-2">
                <div class="col-12">
                    <table class="table table-bordered border-dark data-table">
                        <thead>
                        <tr>
                            <th>State Name</th>
                            <th>Description</th>
                            <th>Terminal</th>
                            <th>Created</th>
                            <th>Updated</th>
                            <th></th>
                        </tr>
                        </thead>
                        <tbody>
                        {{#each states}}
                        {{#with this}}
                            <tr title="ID: {{id}}">
                                <td >{{displayName}}</td>
                                <td>{{description}}</td>
                                <td>{{#if terminal eq true}}Yes{{else}}No{{/if}}</td>
                                <td>{{created}}</td>
                                <td>{{updated}}</td>
                                <td>
                                    <form class="confirmed-form" method="post"
                                          action="/manage/workflow/{{../id}}/states/{{id}}/delete"
                                          data-cnf-title="Deleting state {{name}}"
                                          data-cnf-text="Are you sure you want to delete this state? Action will fail if transitions exist.">
                                        <button type="submit" class="btn btn-link p-0 text-danger"><i
                                                class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        {{/with}}
                        {{/each}}
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    {{/with}}
{{/partial}}


{{#partial "page_js"}}

{{/partial}}
{{> common/base}}