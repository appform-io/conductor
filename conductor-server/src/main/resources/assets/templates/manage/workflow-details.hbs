{{#partial "page_css_includes"}}
    <link href="/css/bootstrap-select.min.css" rel="stylesheet">
{{/partial}}
{{#partial "page_js_includes"}}
    <script type="text/javascript" src="/js/bootstrap-select.min.js"></script>
{{/partial}}
{{#partial "content"}}
    {{#with workflow}}
        <section>
            <div class="row text-center justify-content-center">
                <div class="col-auto"><h2>Details for Workflow {{displayName}}</h2></div>
            </div>
            <div class="row justify-content-center">
                <div class="col-12">
                    <form method="post" action="/manage/workflow/{{id}}" id="workflow-update">
                        <div class="row g-3 m-2">
                            <div class="col-3 text-end">
                                <label for="name" class="col-form-label fw-bold">Name</label>
                            </div>
                            <div class="col-6 p-2">
                                {{displayName}}
                            </div>
                        </div>
                        <div class="row g-3 m-2">
                            <div class="col-3 text-end">
                                <label for="description" class="col-form-label fw-bold">Description</label>
                            </div>
                            <div class="col-6">
                            <textarea id="description" name="description"
                                      class="form-control border border-dark bg-light"
                                      placeholder="A description for the workflow"
                                      maxlength="255">{{description}}</textarea>
                            </div>
                        </div>
                        <div class="row g-3 m-2">
                            <div class="col-3 text-end">
                                <label for="schemaId" class="col-form-label fw-bold">Ticket Schema</label>
                            </div>
                            <div class="col-6">
                                {{../schema/name}}
                            </div>
                        </div>
                        <div class="row g-3 m-2">
                            <div class="col-3 text-end">
                                <label for="titleTemplate" class="col-form-label fw-bold">Title Template</label>
                            </div>
                            <div class="col-6">
                                {{#with titleTemplate}}
                                    <textarea id="titleTemplate" name="titleTemplate"
                                              class="form-control border border-dark bg-light"
                                              placeholder="Handlebars template to extract ticket title from raw payload"
                                              required>{{template}}</textarea>
                                {{/with}}
                            </div>
                        </div>
                        <div class="row g-3 m-2">
                            <div class="col-3 text-end">
                                <label for="descriptionTemplate" class="col-form-label fw-bold">Description
                                    Template</label>
                            </div>
                            <div class="col-6">
                                {{#with descriptionTemplate}}
                                    <textarea id="descriptionTemplate" name="descriptionTemplate"
                                              class="form-control border border-dark bg-light"
                                              placeholder="Handlebars template to extract ticket description from raw payload">{{template}}</textarea>
                                {{/with}}
                            </div>
                        </div>
                        <div class="row g-3 m-2">
                            <div class="col-3 text-end">
                                <label for="subjectTemplate" class="col-form-label fw-bold">Subject ID Template</label>
                            </div>
                            <div class="col-6">
                                {{#with subjectIdTemplate}}
                                    <textarea id="subjectTemplate" name="subjectTemplate"
                                              class="form-control border border-dark bg-light"
                                              placeholder="Handlebars template to extract subject from raw payload">{{template}}</textarea>
                                {{/with}}
                            </div>
                        </div>
                        <div class="row g-3 justify-content-center m-2">
                            <div class="col-auto">
                                <button type="submit" class="btn btn-outline-primary mb-3">Save</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </section>
        <section>
            <div class="row">
                <div class="col-sm-10">
                    <h3>States</h3>
                </div>
                <div class="col-sm-2 d-flex justify-content-end">
                    <a class="btn btn-outline-success" href="/manage/workflow/{{id}}/states/add">Add</a>
                </div>
            </div>
            <div class="row mt-2">
                <div class="col-12">
                    <table class="table table-bordered border-dark data-table">
                        <thead>
                        <tr>
                            <th>State Name</th>
                            <th>Description</th>
                            <th>Terminal</th>
                            <th>Start State</th>
                            <th>Created</th>
                            <th>Updated</th>
                            <th></th>
                        </tr>
                        </thead>
                        <tbody>
                        {{#each states}}
                            {{#with this}}
                                <tr title="ID: {{id}}">
                                    <td><a href="/manage/workflow/{{../id}}/states/{{id}}">{{displayName}}</a></td>
                                    <td>{{description}}</td>
                                    <td>{{#if terminal eq true}}Yes{{else}}No{{/if}}</td>
                                    <td class="text-center">
                                        {{#eq ../startStateId id}}
                                            <i class="bi bi-check-all"></i>Current
                                        {{else}}
                                            <form class="confirmed-form" method="post"
                                                  action="/manage/workflow/{{../id}}/states/{{id}}/initial"
                                                  data-cnf-title="Changing initial state to  {{displayName}}"
                                                  data-cnf-text="Are you sure you want to change initial state of the workflow to {{displayName}}?">
                                                <button type="submit" class="btn btn-link p-0 text-danger">Set</button>
                                            </form>
                                        {{/eq}}
                                    </td>
                                    <td>{{created}}</td>
                                    <td>{{updated}}</td>
                                    <td>
                                        <form class="confirmed-form" method="post"
                                              action="/manage/workflow/{{../id}}/states/{{id}}/delete"
                                              data-cnf-title="Deleting state {{displayName}}"
                                              data-cnf-text="Are you sure you want to delete this state? Action will fail if transitions exist.">
                                            <button type="submit" class="btn btn-link p-0 text-danger">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>

                                </tr>

                            {{/with}}
                        {{/each}}
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
        <section>
            <div class="row">
                <div class="col"><h3>Transitions</h3></div>
            </div>
            <div class="row m-4">
                <div class="col">
                    <form method="post" action="/manage/workflow/{{id}}/transitions/add">
                        <div class="row g-3 m-2">
                            <div class="col-5">
                                <select id="fromState" name="fromState"
                                        class="form-control selectpicker border border-dark bg-light"
                                        data-live-search="true" required>
                                    <option value="" disabled selected>Select from state</option>
                                    {{#each states}}
                                        {{#with this}}
                                            <option value="{{id}}">{{displayName}}</option>
                                        {{/with}}
                                    {{/each}}
                                </select>
                            </div>
                            <div class="col-5">
                                <select id="toState" name="toState"
                                        class="form-control selectpicker border border-dark bg-light"
                                        data-live-search="true" required>
                                                                        <option value="" disabled selected>Select to state</option>
                                    {{#each states}}
                                        {{#with this}}
                                            <option value="{{id}}">{{displayName}}</option>
                                        {{/with}}
                                    {{/each}}
                                </select>
                            </div>
                            <div class="col-2">
                                <select class="form-control selectpicker border border-dark bg-light"
                                        id="transitionType" name="transitionType" required>
                                    <option value="" disabled selected>Transition type</option>
                                    <option value="EVALUATED">Rule based</option>
                                    <option value="DEFAULT">Default</option>
                                </select>
                            </div>
                        </div>
                        <div class="row g-3 m-2">
                            <div class="col-12">
                                <textarea id="rule" name="rule" class="form-control border border-dark bg-light"
                                          maxlength="2048" placeholder="Rule definition"></textarea>
                            </div>
                        </div>
                        <div class="row g-3 m-2">
                            <div class="col-12 d-flex justify-content-center">
                                <select id="transitionAllowedActions" name="allowedActions"
                                        class="form-control selectpicker border border-dark bg-light" multiple
                                        data-live-search="true"  data-selected-text-format="count > 2">
                                    <option value="" disabled selected>Actions to be triggered</option>
                                    {{#each availableActions}}
                                        <option value="{{id}}"
                                                {{#contains state.allowedActions id}}selected{{/contains}}>{{name}}</option>
                                    {{/each}}
                                </select>
                            </div>
                        </div>

                        <div class="row g-3  m-2">
                            <div class="col d-flex justify-content-center">
                                <button type="submit" class="btn btn-outline-success btn-sm"><i class="bi bi-save"></i>Save
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
            <div class="row mt-2">
                <div class="col-12">
                    <table class="table table-bordered border-dark">
                        <thead>
                        <tr>
                            <th>From</th>
                            <th>To</th>
                            <th>Type</th>
                            <th>Rule</th>
                            <th></th>
                        </tr>
                        </thead>
                        <tbody>
                        {{#each ticketStateTransitions}}
                            {{#each this}}
                                <tr>
                                    <td>{{#with (lookup states from)}}{{displayName}}{{/with}}</td>
                                    <td>{{#with (lookup states to)}}{{displayName}}{{/with}}</td>
                                    <td>{{type}}</td>
                                    <td>{{rule.rule}}</td>
                                    <td>
                                        <form class="confirmed-form" method="post"
                                              action="/manage/workflow/{{../id}}/transitions/{{id}}/delete"
                                              data-cnf-title="Deleting transition"
                                              data-cnf-text="Are you sure you want to delete this transition? Action will fail if transitions exist.">
                                            <button type="submit" class="btn btn-link p-0 text-danger"><i
                                                    class="bi bi-trash"></i></button>
                                        </form>
                                    </td>
                                </tr>
                            {{/each}}
                        {{/each}}
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    {{/with}}
{{/partial}}


{{#partial "page_js"}}

{{/partial}}
{{> common/base}}