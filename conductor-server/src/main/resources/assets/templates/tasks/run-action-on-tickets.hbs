{{#partial "page_css_includes"}}
    <link href="/css/bootstrap-select.min.css" rel="stylesheet">
{{/partial}}
{{#partial "page_js_includes"}}
    <script type="text/javascript" src="/js/bootstrap-select.min.js"></script>
{{/partial}}
{{#partial "content"}}
    <section>
        <div class="row">
            <div class="col-12">
                {{#empty task}}
                    <h4>Create new task</h4>
                {{else}}
                    <h4>Updating Task {{task.name}}</h4>
                {{/empty}}
            </div>
        </div>
        <form method="post"
              {{#empty task}}
              action="/manage/tasks/{{workflowId}}/RUN_ACTION_ON_SELECTED_TICKETS"
              {{else}}
              action="/manage/tasks/{{workflowId}}/RUN_ACTION_ON_SELECTED_TICKETS/{{task.id}}/update"
              {{/empty}}>
            <div class="row mt-3">
                <div class="col-12">
                    <div class="mb-3">
                        <label for="name" class="col-form-label fw-bold">Name</label>
                        <input type="text" id="name" name="name"
                               class="form-control border border-dark"
                               maxlength="45" placeholder="Task Name" aria-describedby="nameHelp"
                               value="{{task.name}}" {{#empty task}}required{{else}}disabled{{/empty}}>
                        <div id="nameHelp" class="form-text">Name <i>can not</i> be changed once created. Max Length: 45
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="description" class="col-form-label fw-bold">Description</label>
                        <textarea id="description" name="description"
                                  class="form-control border border-dark"
                                  aria-describedby="descriptionHelp" required
                                  placeholder="A description for the task">{{task.description}}</textarea>
                        <div id="descriptionHelp" class="form-text">Optional, can be upto 255 characters long</div>
                    </div>
                    <div class="mb-3">
                        <label for="cron" class="col-form-label fw-bold">Execution Cron Expression</label>
                        <input type="text" class="form-control  border border-dark" id="cron" name="cron" value="{{task.cron}}"
                               placeholder="Quartz Cron Expression" aria-describedby="cronHelp"
                               maxlength="45" required>
                        <div id="cronHelp" class="form-text">Cron pattern to specify when the task gets triggered.
                            <a href="https://www.quartz-scheduler.org/documentation/quartz-2.3.0/tutorials/crontrigger.html"
                               target="_blank">
                                Follows Quartz cron syntax.
                            </a>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="mode" class="col-form-label fw-bold">Execution Mode</label>
                        <select id="mode" name="mode"
                                class="form-control selectpicker border border-dark" aria-describedby="modeHelp" required>
                            <option disabled value="">Select Mode</option>
                            {{#each modes}}
                                <option value="{{this}}" {{#eq ../mode this}}selected{{/eq}}>{{readable
                                        this}}</option>
                            {{/each}}
                        </select>
                        <div id="modeHelp" class="form-text">Execution mode: Absolute if task mutate tickets, Resumable otherwise
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-12 col-md-6">
                    <div class="row">
                        <div class="col">
                            <h5>Ticket Filters</h5>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12">
                            <div class="mb-3">
                                <label for="stateIds" class="col-form-label fw-bold">States</label>
                                <select id="stateIds" name="stateIds"
                                        class="form-control selectpicker border border-dark" multiple
                                        data-live-search="true"  data-selected-text-format="count > 2">
                                    <option value="">None</option>
                                    {{#each states}}
                                        <option value="{{id}}"
                                                {{#contains ../selectedStates id}}selected{{/contains}}>{{displayName}}
                                        </option>
                                    {{/each}}
                                </select>
                            </div>
                            <div class="mb-3">
                                <label for="updatedBeforeInMins" class="col-form-label fw-bold">Updated Before (Minutes)</label>
                            <input id="updatedBeforeInMins" name="updatedBeforeInMins" type="number"
                                   class="form-control border border-dark"
                                {{#neq updatedBeforeInMins 0}}
                                   value="{{updatedBeforeInMins}}"
                                {{/neq}}>
                            </div>
                            <div class="mb-3">
                                <label for="groupIds" class="col-form-label fw-bold">Group</label>
                                <select id="groupIds" name="groupIds"
                                        class="form-control selectpicker border border-dark" multiple
                                        data-live-search="true"  data-selected-text-format="count > 2">
                                    <option value="">None</option>
                                    {{#each groups}}
                                        <option value="{{id}}"
                                                {{#contains ../selectedGroups id}}selected{{/contains}}>{{name}}</option>
                                    {{/each}}
                                </select>
                            </div>
                            <div class="mb-3">
                                <label for="priorities" class="col-form-label fw-bold">Priorities</label>
                                <select id="priorities" name="priorities"
                                        class="form-control selectpicker border border-dark" multiple
                                        data-live-search="true"  data-selected-text-format="count > 2">
                                    <option value="">None</option>
                                    {{#each priorities}}
                                        <option value="{{id}}"
                                                {{#contains ../selectedPriorities this}}selected{{/contains}}>{{this}}</option>
                                    {{/each}}
                                </select>
                            </div>
                            <div class="mb-3">
                                <label for="userAssignmentStatus" class="col-form-label fw-bold">User Assignment Status</label>
                                <select id="userAssignmentStatus" name="userAssignmentStatus"
                                        class="form-control selectpicker border border-dark">
                                    <option value="">None</option>
                                    {{#each userAssignmentStatuses}}
                                        <option value="{{this}}" {{#eq ../userAssignmentStatus this}}selected{{/eq}}>{{readable
                                                this}}</option>
                                    {{/each}}
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-6">
                    <div class="row">
                        <div class="col">
                            <h5>Actions to be applied</h5>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-8 col-md-10">
                            <label for="selectedActions" class="col-form-label fw-bold visually-hidden">Allowed
                                Actions</label>
                            <select id="selectedActions" name="selectedActions"
                                    class="form-control selectpicker border border-dark" multiple required
                                    aria-describedby="selectedActionsHelp"
                                    data-live-search="true" data-selected-text-format="count > 2">
                                {{#each availableActions}}
                                    <option value="{{id}}"
                                            {{#contains ../task/spec/actionIds id}}selected{{/contains}}>{{name}}</option>
                                {{/each}}
                            </select>
                            <div id="selectedActionsHelp" class="form-text">
                                Actions to be executed on the selected tickets
                            </div>
                        </div>
                        <div class="col-4 col-md-2 justify-content-center">
                            <a role="button" href="/actions/WORKFLOW/{{workflowId}}" class="btn btn-primary btn-sm"
                               target="_blank">
                                <i class="bi bi-plus-lg">New Action</i>
                            </a>
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="col-12 table-responsive">
                            <table class="table table-bordered border-dark">
                                <thead>
                                <tr>
                                    <th class="col-4">Name</th>
                                    <th class="col-4">Description</th>
                                    <th class="col-2 text-center">Type</th>
                                    <th class="col-2 text-center">Scope</th>
                                </tr>
                                </thead>
                                <tbody>
                                {{#each availableActions}}
                                {{#contains task.spec.actionIds id}}
                                    <tr>
                                        <td>{{name}}</td>
                                        <td>{{description}}</td>
                                        <td class="text-center">{{readable type}}</td>
                                        <td class="text-center">
                                            {{#eqEnum scope.type "GLOBAL"}}
                                                Global
                                            {{else}}
                                                Local
                                            {{/eqEnum}}
                                        </td>
                                    </tr>
                                {{/contains}}

                                {{/each}}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row mt-3">
                <div class="col-12 d-flex justify-content-center">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save">Save</i>
                    </button>
                </div>
            </div>
        </form>
    </section>
{{/partial}}
{{> common/base}}

