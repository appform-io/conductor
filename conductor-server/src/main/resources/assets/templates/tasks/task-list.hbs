{{#partial "page_css_includes"}}
    <link href="/css/bootstrap-select.min.css" rel="stylesheet">
{{/partial}}
{{#partial "page_js_includes"}}
    <script type="text/javascript" src="/js/bootstrap-select.min.js"></script>
{{/partial}}
{{#partial "content"}}
    <section>
        <div class="row mb-3">
            <div class="col-12">
                <h3>Task Management<!-- for {{readable scope.type}} : {{scope.referenceId}}--></h3>
            </div>
        </div>
        <form method="post" action="/manage/tasks/{{workflowId}}">
            <div class="row row-cols-lg-auto g-3 align-items-center">
                <div class="col-12">
                    <label for="taskType" class="col-form-label fw-bold">Task Type</label>
                </div>
                <div class="col-12">
                    <select id="taskType" name="taskType"
                            class="form-control selectpicker border border-dark" required>
                        {{#each types}}
                            <option value="{{this}}">
                                {{readable this}}
                            </option>
                        {{/each}}
                    </select>
                </div>
                <div class="col-12 justify-content-end text-end">
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </div>
        </form>
        <div class="row mt-3">
            <div class="col-12 table-responsive">
                <table class="table table-bordered border-dark data-table">
                    <thead>
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Type</th>
                        <th>Scope</th>
                        <th>Scope Reference</th>
                        <th>Execution Interval</th>
                        <th>State</th>
                        <th>Last Execution Time</th>
                        <th>Last Run Status</th>
                        <th>Last Updated</th>
                        <th></th>
                    </tr>
                    </thead>
                    <tbody>
                    {{#each tasks}}
                    <tr>
                        <td><a href="/manage/tasks/{{workflowId}}/{{id}}">{{name}}</a></td>
                        <td>{{description}}</td>
                        <td>{{readable type}}</td>
                        <td>{{readable scope.type}}</td>
                        <td>{{readable scope.referenceId}}</td>
                        <td>{{interval}}</td>
                        <td>{{state}}</td>
                        <td>{{lastExecutionCompletionTime}}</td>
                        <td>{{readable status}}</td>
                        <td>{{updated}}</td>
                        <td></td>
                    </tr>
                    {{/each}}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
{{/partial}}
{{> common/base}}