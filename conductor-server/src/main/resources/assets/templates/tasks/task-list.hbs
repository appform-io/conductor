{{#partial "page_css_includes"}}
    <link href="/css/bootstrap-select.min.css" rel="stylesheet">
{{/partial}}
{{#partial "page_js_includes"}}
    <script type="text/javascript" src="/js/bootstrap-select.min.js"></script>
{{/partial}}
{{#partial "content"}}
    <section>
        <div class="row mb-3">
            <div class="col-12">
                <h3>Task Management<!-- for {{readable scope.type}} : {{scope.referenceId}}--></h3>
            </div>
        </div>
        <form method="post" action="/manage/tasks/{{workflowId}}">
            <div class="row row-cols-lg-auto g-3 align-items-center">
                <div class="col-12">
                    <label for="taskType" class="col-form-label fw-bold">Task Type</label>
                </div>
                <div class="col-12">
                    <select id="taskType" name="taskType"
                            class="form-control selectpicker border border-dark" required>
                        {{#each types}}
                            <option value="{{this}}">
                                {{readable this}}
                            </option>
                        {{/each}}
                    </select>
                </div>
                <div class="col-12 justify-content-end text-end">
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </div>
        </form>
        <div class="row mt-3">
            <div class="col-12 table-responsive">
                <table class="table table-bordered border-dark data-table">
                    <thead>
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Type</th>
                        <th>Scope</th>
                        <th>Scope Reference</th>
                        <th>Execution Cron Expression</th>
                        <th>State</th>
                        <th>Last Execution Time</th>
                        <th>Last Run Status</th>
                        <th>Last Updated</th>
                        <th></th>
                        <th></th>
                    </tr>
                    </thead>
                    <tbody>
                    {{#each tasks}}
                    <tr>
                        <td><a href="/manage/tasks/{{workflowId}}/{{id}}">{{name}}</a></td>
                        <td>{{description}}</td>
                        <td>{{readable type}}</td>
                        <td>{{readable scope.type}}</td>
                        <td>{{readable scope.referenceId}}</td>
                        <td>{{cron}}</td>
                        <td>
                            {{#eqEnum state "ACTIVE"}}
                                <span class="badge bg-primary ms-2">Active</span>
                            {{/eqEnum}}
                            {{#eqEnum state "PAUSED"}}
                                <span class="badge bg-secondary ms-2">Paused</span>
                            {{/eqEnum}}
                        </td>
                        <td>{{lastExecutionCompletionTime}}</td>
                        <td>{{readable status}}</td>
                        <td>{{updated}}</td>
                        <td class="text-center">
                            {{#eqEnum state "ACTIVE"}}
                                <form class="confirmed-form" method="post"
                                      action="/manage/tasks/{{workflowId}}/{{id}}/pause"
                                      data-cnf-title="Pausing task {{name}}"
                                      data-cnf-text="Are you sure you want to pause this task?">
                                    <button type="submit" class="btn btn-link p-0 text-primary" title="Pause task"><i
                                            class="bi bi-pause-circle"></i></button>
                                </form>
                            {{/eqEnum}}
                            {{#eqEnum state "PAUSED"}}
                                <form class="confirmed-form" method="post"
                                      action="/manage/tasks/{{workflowId}}/{{id}}/activate"
                                      data-cnf-title="Activating task {{name}}"
                                      data-cnf-text="Are you sure you want to activate this task?">
                                    <button type="submit" class="btn btn-link p-0 text-primary" title="Activate Task"><i
                                            class="bi bi-play-circle"></i></button>
                                </form>
                            {{/eqEnum}}
                        </td>
                        <td class="text-center">
                            <form class="confirmed-form" method="post" action="/manage/tasks/{{workflowId}}/{{id}}/delete"
                                  data-cnf-title="Deleting task {{name}}"
                                  data-cnf-text="Are you sure you want to delete this task?">
                                <button type="submit" class="btn btn-link p-0 text-danger" title="Delete task permanently"><i
                                        class="bi bi-trash-fill"></i></button>
                            </form>
                        </td>
                    </tr>
                    {{/each}}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
{{/partial}}
{{> common/base}}