{{#partial "page_css_includes"}}
    <link href="/css/bootstrap-select.min.css" rel="stylesheet">
{{/partial}}
{{#partial "page_js_includes"}}
    <script type="text/javascript" src="/js/bootstrap-select.min.js"></script>
{{/partial}}
{{#partial "content"}}
    <div class="row">
        <div class="col-12">
            <form class="get" action="/tickets/list">
                <div class="row">
                    <div class="col-sm12 col-md-4">
                        <label for="workflowId" class="col-form-label fw-bold">Workflow</label>
                        <select id="workflowId" name="workflowId"
                                class="form-control selectpicker border border-dark"
                                data-live-search="true" {{#empty workflowId}}{{else}}disabled{{/empty}}>
                            <option disabled selected>Select a workflow</option>
                            {{#each workflows}}
                                <option value="{{id}}"
                                        {{#eq ../workflowId id}}selected{{/eq}}>{{displayName}}</option>
                            {{/each}}
                        </select>
                    </div>
                    <div class="col-sm12 col-md-4">
                        <label for="priority" class="col-form-label fw-bold">Priority</label>
                        <select id="priority" name="priority"
                                class="form-control selectpicker border border-dark"
                                data-live-search="true">
                            <option disabled selected>Select priority</option>
                            {{#each priorities}}
                                <option value="{{this}}" {{#eq ../priority this}}selected{{/eq}}>{{readable
                                        this}}</option>
                            {{/each}}
                        </select>
                    </div>
                    <div class="col-sm12 col-md-4">
                        <label for="stateIds" class="col-form-label fw-bold">States</label>
                        <select id="stateIds" name="stateIds"
                                class="form-control selectpicker border border-dark"
                                data-live-search="true" multiple>
                            {{#empty states}}
                                <option selected disabled>Select workflow first</option>
                            {{/empty}}
                            {{#each states}}
                                <option value="{{id}}"
                                        {{#contains ../stateIds id}}selected{{/contains}}>{{displayName}}</option>
                            {{/each}}
                        </select>
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-12 col-md-3">
                        <label for="subjectId" class="col-form-label fw-bold">Subject ID</label>
                        <input type="text" id="subjectId" name="subjectId"
                               class="form-control border border-dark"
                               placeholder="Enter subject ID"
                               value="{{subjectId}}">
                    </div>
                    <div class="col-sm-12 col-md-3">
                        <label for="createdById" class="col-form-label fw-bold">Created By</label>
                        <input type="text" id="createdById" name="createdById"
                               class="form-control border border-dark"
                               placeholder="User ID of the creator"
                               value="{{createdById}}">
                    </div>
                    <div class="col-sm-12 col-md-3">
                        <label for="groupId" class="col-form-label fw-bold">Subject ID</label>
                        <select type="text" id="groupId" name="groupId"
                                class="form-control selectpicker border border-dark"
                                data-live-search="true">
                            <option selected disabled>Select a group</option>
                            {{#each groups}}
                                <option value="id" {{#eq ../groupId id}}selected{{/eq}}>{{name}}</option>
                            {{/each}}
                        </select>
                    </div>
                    <div class="col-sm-12 col-md-3">
                        <label for="createdById" class="col-form-label fw-bold">Created By</label>
                        <input type="text" id="createdById" name="createdById"
                               class="form-control border border-dark"
                               placeholder="User ID of the assignee"
                               value="{{assignedToId}}">
                    </div>
                </div>
                <div class="row">
                    <div class="col-12 d-flex justify-content-center">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search"></i> Search
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
{{/partial}}

{{> common/base}}