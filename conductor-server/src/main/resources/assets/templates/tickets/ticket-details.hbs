{{#partial "page_css_includes"}}
    <link href="/css/bootstrap-select.min.css" rel="stylesheet">
{{/partial}}
{{#partial "page_js_includes"}}
    <script type="text/javascript" src="/js/bootstrap-select.min.js"></script>
{{/partial}}
{{#partial "content"}}
    {{#with ticket}}
        <div class="row">
            <div class="col">
                <h4>Details for ticket: <b>{{summary/id}}</b></h4>
                <p>
                    <small>Created by <a href="/admin/users/{{summary/createdBy/id}}">
                        <b>{{summary/createdBy/name}}</b></a> on {{summary/created}}. Last updated
                        on {{summary/updated}}.
                    </small>
                </p>
            </div>
        </div>
        <section>
            <div class="row">
                <div class="col-sm-12 col-md-8">
                    <div class="row mt-2">
                        <div class="col-sm-12 col-md-8">
                            <label for="workflow" class="col-form-label fw-bold">Workflow</label>
                            <input type="text" id="workflow"
                                   class="form-control border border-dark"
                                   maxlength="45" value="{{workflow/displayName}}"
                                   aria-describedby="workflowHelp" disabled>
                            <div id="workflowHelp" class="form-text">Workflow
                                Description: {{workflow/displayName}}</div>
                        </div>
                        <div class="col-sm-12 col-md-4">
                            <label for="currentState" class="col-form-label fw-bold">Current State</label>
                            <input type="text" id="currentState"
                                   class="form-control border border-dark"
                                   maxlength="45" value="{{state/displayName}}"
                                   aria-describedby="workflowStateHelp" disabled>
                            <div id="workflowStateHelp" class="form-text">Current state of the workflow.</div>
                        </div>
                    </div>
                    {{#with summary}}
                        <form method="post" action="/tickets/{{summary/id}}/summary/update">
                            <div class="mb-3">
                                <label for="title" class="col-form-label fw-bold">Title</label>
                                <input type="text" id="title" name="title"
                                       class="form-control border border-dark"
                                       maxlength="45" aria-describedby="titleHelp" placeholder="Ticket title"
                                       value="{{title}}" required>
                                <div id="titleHelp" class="form-text">
                                    A human-readable title for this ticket. Max Length: 255.
                                </div>
                            </div>
                            <div class="mb-3">
                                <label for="description" class="col-form-label fw-bold">Description</label>
                                <textarea id="description" name="description"
                                          class="form-control border border-dark"
                                          maxlength="45" placeholder="Ticket description"
                                          aria-describedby="descriptionHelp" rows="10">{{description}}</textarea>
                                <div id="descriptionHelp" class="form-text">
                                    A detailed description of the issue. Max Length: 4096.
                                </div>
                            </div>
                            <div class="mb-3 d-flex justify-content-end">
                                <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> Update</button>
                            </div>
                        </form>
                    {{/with}}
                    <section class="mb-2">
                        <div class="row mb-2">
                            <div class="col-12 col-md-7">
                                <h5>Related Tickets</h5>
                            </div>
                            <div class="col-12 col-md-5 d-flex justify-content-end">

                                <form class="row row-cols-md-auto g-3 align-items-center" method="post"
                                    action="/tickets/{{summary.id}}/reference/create">
                                    <div class="col-10">
                                        <label for="relTicketId" class="col-form-label fw-bold visually-hidden">Name</label>
                                        <input type="text" id="relTicketId" name="relTicketId" class="form-control border border-dark"
                                               maxlength="45" placeholder="Ticket id to relate to" required>
                                    </div>
                                    <div class="col-2">
                                        <button type="submit" title="Link to ticket" class="btn btn-primary"><b class="bi bi-link-45deg"></b></button>
                                    </div>
                                </form>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-12 table-responsive">
                                <table class="table table-bordered datatable">
                                    <thead>
                                        <tr>
                                            <th>ID</th>
                                            <th>Title</th>
                                            <th>Relation</th>
                                            <th>Created</th>
                                            <th>Updated</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                    {{#each ../relatedTickets}}
                                        <tr>
                                            <td><a href="/tickets/{{ticketId}}/details">{{ticketId}}</a></td>
                                            <td>{{title}}</td>
                                            <td>{{readable relationship}}</td>
                                            <td>{{htmlDate created true}}</td>
                                            <td>{{htmlDate updated true}}</td>
                                            <td>
                                                <form class="confirmed-form" method="post"
                                                      action="/tickets/{{../ticket/summary/id}}/reference/{{ticketId}}/delete"
                                                      data-cnf-title="Deleting reference"
                                                      data-cnf-text="Are you sure you want to delete this ticket reference?">
                                                    <button type="submit" class="btn btn-link p-0 text-danger"><i
                                                            class="bi bi-trash-fill"></i></button>
                                                </form>
                                            </td>
                                        </tr>
                                    {{/each}}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </section>
                    <div class="row">
                        <div class="col-12">
                            <ul class="nav nav-tabs" id="ticketExtra" role="tablist">
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link active" id="comments-tab" data-bs-toggle="tab"
                                            data-bs-target="#comments-tab-pane" type="button" role="tab"
                                            aria-controls="comments-tab-pane" aria-selected="true">Comments</button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="events-tab" data-bs-toggle="tab"
                                            data-bs-target="#events-tab-pane" type="button" role="tab"
                                            aria-controls="events-tab-pane" aria-selected="false">Events</button>
                                </li>
                            </ul>
                            <div class="tab-content" id="ticketExtraContent">
                                <div class="tab-pane fade show active" id="comments-tab-pane" role="tabpanel"
                                     aria-labelledby="comments-tab" tabindex="0">

                                </div>
                                <div class="tab-pane fade" id="events-tab-pane" role="tabpanel" aria-labelledby="events-tab" tabindex="0">

                                </div>
                            </div>

                        </div>
                    </div>

                </div>
                <div class="col-sm-12 col-md-4 mt-2">
                    <div class="row">
                        <div class="col-12 p-4 mb-3 border border-dark">
                            <label for="subId" class="col-form-label fw-bold"><i class="bi bi-person-lines-fill"></i>
                                &nbsp; Subject</label>
                            <a id="subId" class="ms-1" aria-describedby="subIdHelp"
                               href="/subjects/{{summary/subject/globalId}}/details">
                                {{#empty summary.subject.name}}
                                    {{summary/subject/globalId}}
                                {{else}}
                                    {{summary.subject.name}}
                                {{/empty}}
                            </a>
                            <div id="subIdHelp" class="form-text">
                                Person who is the subject of this ticket
                            </div>
                        </div>
                    </div>
                    <div class="accordion accordion-flush border border-dark" id="ticketSections">
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button bg-dark text-white collapsed" type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#flush-assignment" aria-expanded="false"
                                        aria-controls="flush-assignment">
                                    <i class="bi bi-arrow-down-up"></i> &nbsp; Priority
                                </button>
                            </h2>
                            <div id="flush-assignment" class="accordion-collapse collapse show"
                                 data-bs-parent="#ticketSections">
                                <div class="accordion-body">
                                    <form method="post" action="/tickets/{{summary.id}}/priority/update">
                                        <div class="row">
                                            <div class="col-sm-4 col-md-2">
                                                <label for="priority" class="col-form-label fw-bold">Priority</label>
                                            </div>
                                            <div class="col-8">
                                                <select id="priority" name="priority"
                                                        class="form-control selectpicker border border-dark"
                                                        aria-describedby="priorityHelp" required>
                                                    {{#each ../priorities}}
                                                        <option value="{{this}}"
                                                                {{#eq this summary.priority}}selected{{/eq}}>
                                                            {{readable this}}
                                                        </option>
                                                    {{/each}}
                                                </select>
                                                <div id="priorityHelp" class="form-text">
                                                    Priority for this ticket.
                                                    Handling of priority is dependent on state transition rules.
                                                </div>
                                            </div>
                                            <div class="col justify-content-end text-end">
                                                <button type="submit" class="btn btn-primary">Set</button>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button bg-dark text-white collapsed" type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#flush-assignment" aria-expanded="false"
                                        aria-controls="flush-assignment">
                                    <i class="bi bi-people-fill"></i> &nbsp; Assignment
                                </button>
                            </h2>
                            <div id="flush-assignment" class="accordion-collapse collapse show"
                                 data-bs-parent="#ticketSections">
                                <div class="accordion-body">
                                    <div class="row">
                                        <div class="col-12">
                                            <form method="post" action="/tickets/{{summary.id}}/group/update">
                                                <div class="row">
                                                    <div class="col-sm-4 col-md-2">
                                                        <label for="groupId"
                                                               class="col-form-label fw-bold">Group</label>
                                                    </div>
                                                    <div class="col-sm-8 col-md-8">
                                                        <select id="groupId" name="groupId"
                                                                class="form-control selectpicker border border-dark"
                                                                aria-describedby="groupIdHelp" data-live-search="true">
                                                            {{#each ../availableGroups}}
                                                                <option value="{{id}}"
                                                                        {{#eq id
                                                                              summary/assignedToGroup/id}}selected{{/eq}}>
                                                                    {{name}}
                                                                </option>
                                                            {{/each}}
                                                        </select>
                                                        <div id="groupIdHelp" class="form-text">Group to assign this
                                                            ticket to
                                                        </div>
                                                    </div>
                                                    <div class="col justify-content-end text-end">
                                                        <button type="submit" class="btn btn-primary">Assign</button>
                                                    </div>
                                                </div>

                                            </form>

                                        </div>
                                    </div>
                                    <div class="row mt-3">
                                        {{#eq summary/assignedToUser/id ../currentUser/summary/id}}
                                            <div class="col-9">
                                                Ticket is assigned to user: <b>{{summary/assignedToUser/name}}</b>.
                                            </div>
                                            <div class="col-3 d-flex justify-content-end">
                                                <form method="post" action="/tickets/{{summary.id}}/unassign">
                                                    <div class="col justify-content-end text-end">
                                                        <button type="submit" class="btn btn-danger btn-sm">Un-Assign
                                                        </button>
                                                    </div>
                                                </form>
                                            </div>
                                        {{else}}
                                            <div class="col-9">
                                                Ticket is currently not assigned to anyone.
                                            </div>
                                            <div class="col-3 d-flex justify-content-end">
                                                <form method="post" action="/tickets/{{summary.id}}/assign">
                                                    <div class="col justify-content-end text-end">
                                                        <button type="submit" class="btn btn-success sm">Assign to me
                                                        </button>
                                                    </div>
                                                </form>
                                            </div>
                                        {{/eq}}

                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button bg-dark text-white collapsed" type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#flush-actions" aria-expanded="false"
                                        aria-controls="flush-actions">
                                    <i class="bi bi-braces-asterisk"></i> &nbsp; Available Actions
                                </button>
                            </h2>
                            <div id="flush-actions" class="accordion-collapse collapse show"
                                 data-bs-parent="#ticketSections">
                                <div class="accordion-body">
                                        <div class="row">
                                            <div class="col-12">
                                                <table class="table table-bordered">
                                                    <tbody>
                                                    {{#each ../visibleActions}}
                                                    <tr>
                                                        <td title="{{description}}">{{name}}</td>
                                                        <td class="text-center">
                                                            <form method="post"
                                                                  action="/tickets/{{summary.id}}/actions/{{id}}/execute">
                                                                <button type="submit" class="btn btn-sm btn-outline-primary">
                                                                    <i class="bi bi-caret-right-fill"></i>
                                                                </button>
                                                            </form>
                                                        </td>
                                                    </tr>
                                                    {{/each}}

                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button  bg-dark text-white collapsed" type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#flush-ticketFieldsSet" aria-expanded="false"
                                        aria-controls="flush-ticketFieldsSet">
                                    <i class="bi bi-file-ruled"></i> &nbsp; Fields
                                </button>
                            </h2>
                            <div id="flush-ticketFieldsSet" class="accordion-collapse collapse show"
                                 data-bs-parent="#ticketSections">
                                <div class="accordion-body">
                                    <form class="p-2" method="post" action="/tickets/{{summary/id}}/fields/update">

                                        {{#each ../fields}}
                                            <div class="mb-3">
                                                <label for="ticketField-{{schema/name}}"
                                                       class="col-form-label fw-bold">{{schema/displayName}}</label>
                                                {{#fieldTypeEquals type "STRING"}}
                                                    <input type="text"
                                                           class="form-control border border-dark"
                                                           id="ticketField-{{schema/name}}"
                                                           name="ticketField-{{schema/name}}"
                                                           aria-describedby="ticketField-{{schema/name}}-Help"
                                                        {{#gt schema/maxLength
                                                              0}}maxlength="{{schema/maxLength}}" {{/gt}}
                                                        {{#empty
                                                                schema/matchPattern}}{{else}}pattern="{{schema/matchPattern}}" {{/empty}}
                                                        {{#empty
                                                                fieldValue}}{{else}}value="{{fieldValue/value}}" {{/empty}}
                                                        {{#eq editable true}}
                                                            {{#eq required true}}required{{/eq}}
                                                        {{else}}
                                                           disabled
                                                        {{/eq}}>
                                                {{/fieldTypeEquals}}
                                                {{#fieldTypeEquals type "CHOICE"}}
                                                    <select class="form-control selectpicker border border-dark"
                                                            data-live-search="true"
                                                            data-selected-text-format="count > 2"
                                                            id="ticketField-{{schema/name}}"
                                                            name="ticketField-{{schema/name}}"
                                                            aria-describedby="ticketField-{{schema/name}}-Help"
                                                        {{#eq schema/allowMultiple true}}multiple{{/eq}}
                                                        {{#eq editable true}}
                                                            {{#eq required true}}required{{/eq}}
                                                        {{else}}
                                                            disabled
                                                        {{/eq}}>
                                                        {{#empty value}}
                                                            <option {{#eq schema/allowMultiple false}}selected{{/eq}} disabled>Select an option</option>
                                                        {{/empty}}
                                                        {{#each schema/choices}}
                                                            <option value="{{value}}" {{#empty
                                                                    fieldValue}}{{else}}{{#contains
                                                                    ../fieldValue/value
                                                                    value}}selected{{/contains}}{{/empty}}>
                                                                {{displayText}}
                                                            </option>
                                                        {{/each}}
                                                    </select>

                                                {{/fieldTypeEquals}}
                                                {{#fieldTypeEquals type "BOOLEAN"}}
                                                    <select class="form-control selectpicker border border-dark"
                                                            data-live-search="true"
                                                            id="ticketField-{{schema/name}}"
                                                            name="ticketField-{{schema/name}}"
                                                            aria-describedby="ticketField-{{schema/name}}-Help"
                                                        {{#eq editable true}}
                                                            {{#eq required true}}required{{/eq}}
                                                        {{else}}
                                                            disabled
                                                        {{/eq}}>
                                                        <option value="" disabled>Select option</option>
                                                        <option value="true"
                                                                {{#eq fieldValue/value true}}selected{{/eq}}>Yes
                                                        </option>
                                                        <option value="false"
                                                                {{#eq fieldValue/value false}}selected{{/eq}}>No
                                                        </option>
                                                    </select>
                                                {{/fieldTypeEquals}}
                                                {{#fieldTypeEquals type "LOCATION"}}

                                                {{/fieldTypeEquals}}
                                                {{#fieldTypeEquals type "DATE"}}
                                                    <input type="date"
                                                           class="form-control border border-dark"
                                                           id="ticketField-{{schema/name}}"
                                                           name="ticketField-{{schema/name}}"
                                                           aria-describedby="ticketField-{{schema/name}}-Help"
                                                        {{#empty schema/max}}{{else}}max="{{schema/max}}" {{/empty}}
                                                        {{#empty schema/min}}{{else}}max="{{schema/max}}" {{/empty}}
                                                        {{#empty fieldValue}}{{else}}value="{{htmlDate fieldValue/value
                                                                                                       false}}" {{/empty}}
                                                        {{#eq editable true}}
                                                            {{#eq required true}}required{{/eq}}
                                                        {{else}}
                                                           disabled
                                                        {{/eq}}>
                                                {{/fieldTypeEquals}}
                                                {{#fieldTypeEquals type "NUMBER"}}
                                                    <input type="number"
                                                           class="form-control border border-dark"
                                                           id="ticketField-{{schema/name}}"
                                                           name="ticketField-{{schema/name}}"
                                                           aria-describedby="ticketField-{{schema/name}}-Help"
                                                        {{#neq schema/max 0}}max="{{schema/max}}" {{/neq}}
                                                        {{#neq schema/min 0}}min="{{schema/min}}" {{/neq}}
                                                        {{#empty
                                                                fieldValue}}{{else}}value="{{fieldValue/value}}" {{/empty}}
                                                        {{#eq editable true}}
                                                            {{#eq required true}}required{{/eq}}
                                                        {{else}}
                                                           disabled
                                                        {{/eq}}>
                                                {{/fieldTypeEquals}}
                                                <div id="ticketField-{{schema/name}}-Help" class="form-text">
                                                    {{schema/description}}
                                                </div>
                                            </div>
                                        {{/each}}
                                        <div class="mb-3 mt-2 d-flex justify-content-center">
                                            <button type="submit" class="btn btn-info"><i
                                                    class="bi bi-cloud-plus-fill"></i>
                                                Submit
                                            </button>
                                        </div>
                                    </form>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    {{/with}}
{{/partial}}

{{#partial "page_js"}}
    $.get('/tickets/{{ticket.summary.id}}/comments', data => $('#comments-tab-pane').html(data));
{{/partial}}

{{> common/base}}
