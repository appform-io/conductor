{{#partial "content"}}
    <section>
        <div class="row">
            <div class="col-12 col-md-6">
                <div class="row">
                    <div class="col-auto">
                        {{#empty currentReport}}
                            <h4>Schedule a new report</h4>
                        {{else}}
                            <h4>Updating report: <b>{{currentReport.name}}</b></h4>
                        {{/empty}}
                    </div>
                </div>
                <form method="post"
                    {{#empty currentReport}}
                      action="/manage/reports"
                    {{else}}
                      action="/manage/reports/{{currentReport.id}}/update"
                    {{/empty}}
                >
                    <div class="row">
                        <div class="col-12">
                            <div class="mb-3">
                                <label for="name" class="col-form-label fw-bold">Name</label>
                                <input type="text" id="name" name="name" class="form-control border border-dark"
                                       maxlength="45" placeholder="Report Name" aria-describedby="nameHelp"
                                       value="{{currentReport.name}}"
                                       {{#empty currentReport}}required{{else}}disabled{{/empty}}
                                >
                                <div id="nameHelp" class="form-text">Name <i>can not</i> be changed once created</div>
                            </div>
                            <div class="mb-3">
                                <label for="description" class="col-form-label fw-bold">Description</label>
                                <textarea id="description" name="description"
                                          class="form-control border border-dark" rows="5"
                                          placeholder="A description for the report" aria-describedby="descriptionHelp"
                                          aria-describedby="descriptionHelp">{{currentReport.description}}</textarea>
                                <div id="descriptionHelp" class="form-text">Optional, can be upto 255 characters long</div>
                            </div>
                            <div class="mb-3">
                                <label for="cqlQuery" class="col-form-label fw-bold">CQL Query</label>
                                <input type="text" id="cqlQuery" name="cqlQuery" class="form-control border border-dark"
                                       maxlength="45" placeholder="CQL Query" aria-describedby="cqlQueryHelp"
                                       value="{{currentReport.cqlQuery}}" required>
                                <div id="cqlQueryHelp" class="form-text">CQL Query that will be run to select records</div>
                            </div>
                            <div class="mb-3">
                                <label for="cron" class="col-sm-2 col-form-label fw-bold">Cron Pattern</label>
                                <input type="text" class="form-control  border border-dark" id="cron" name="cron" value="{{currentReport.cron}}"
                                       placeholder="Quartz Cron Expression" aria-describedby="cronHelp" required>
                                <div id="cqlQueryHelp" class="form-text">Cron pattern to specify when the report gets triggered.
                                    Follows Quartz cron syntax.
                                </div>
                            </div>
                            <div class="mb-3">
                                <label for="recipients" class="col-sm-2 col-form-label fw-bold">Recipient Emails</label>
                                <input type="text" class="form-control  border border-dark" id="recipients" name="recipients"
                                       value="{{join currentReport.recipients}}"
                                       placeholder="Comma separated list of recipients" aria-describedby="recipientsHelp"
                                       required>
                                <div id="recipientsHelp" class="form-text">List of email IDs that the report will be mailed to
                                </div>
                            </div>
                            <div class="mb-3">
                                <button type="submit" class="btn btn-success mb-3"><i class="bi bi-save"></i> Save</button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="col-12 col-md-6">
                <div class="row mb-2">
                    <div class="col-sm-12 col-md-7"><h4>Reports</h4></div>
                    <div class="col-sm-12 col-md-5 d-flex justify-content-end">
                        <div class="btn-toolbar" role="toolbar">
                            <div class="btn-group me-2" role="group">
                                <div class="input-group border border-dark col-3">
                                    <span class="input-group-text" id="search-box"><i class="bi fs2 bi-search"></i></span>
                                    <input type="text" class="form-control form-control-sm  data-table-search"
                                           id="reports-search"
                                           placeholder="Search roles" aria-label="Search roles" aria-describedby="search-box">
                                </div>
                            </div>
                            <div class="btn-group pt-1 pb-1" role="group">
                                <a href="/manage/reports" class="btn btn-sm btn-success" role="button"><i
                                        class="bi fs2 bi-plus-lg"></i>Create</a>
                            </div>

                        </div>

                    </div>
                </div>
                <div class="row">
                    <div class="col-12 table-responsive">
                        <table class="table table-bordered border-dark data-table" data-table-search="#reports-search">
                            <thead>
                            <tr>
                                <th>Name</th>
                                <th>Description</th>
                                <th>CQL</th>
                                <th>Cron</th>
                                <th>Recipients</th>
                                <th>State</th>
                                <th>Provisioned By</th>
                                <th>Created</th>
                                <th>Last Updated</th>
                                <th class="col"></th>
                            </tr>
                            </thead>
                            <tbody>
                            {{#each reports}}
                                <tr>
                                    <td><a href="/manage/reports/{{id}}">{{name}}</a></td>
                                    <td>{{description}}</td>
                                    <td><code>{{cqlQuery}}</code></td>
                                    <td><code>{{cron}}</code></td>
                                    <td>{{join recipients}}</td>
                                    <td>{{readable state}}</td>
                                    <td>{{provisionedBy}}</td>
                                    <td>{{created}}</td>
                                    <td>{{updated}}</td>
                                    <td class="col d-flex justify-content-center">
                                        <div class="btn-toolbar" role="toolbar">
                                            <div class="btn-group" role="group">
                                                <form class="confirmed-form" method="post" action="/manage/reports/{{id}}/toggle"
                                                      data-cnf-title="Toggling activation state for report {{name}}"
                                                      data-cnf-text="Are you sure you want to toggle state for this report?">
                                                    <button type="submit" class="btn btn-link p-0 text-danger"><i
                                                            class="bi bi-trash-fill"></i></button>
                                                </form>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            {{/each}}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section>
        <div class="row">
            <div class="col-12 col-md-6">

            </div>
            <div class="col-12 col-md-6"></div>
        </div>
    </section>
{{/partial}}
{{> common/base}}