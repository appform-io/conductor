{{#partial "content"}}
<h4>Create New Dashboard</h4>
<div class="row">
    <div class="col-12">
        <form action="/dashboards/create" method="post">
            <div class="mb-3">
                <label for="name" class="col-form-label fw-bold">Name</label>
                <input type="text" id="name" name="name" class="form-control border border-dark"
                       maxlength="45" placeholder="Dashboard Name" aria-describedby="nameHelp">
                <div id="nameHelp" class="form-text">Name for the dashboard. Max Length: 45</div>
            </div>
            <div class="mb-3">
                <label for="description" class="col-form-label fw-bold">Description</label>
                <textarea id="description" name="description"
                          class="form-control border border-dark" rows="5" maxlength="255"
                          placeholder="A description for the dashboard" aria-describedby="descriptionHelp"></textarea>
                <div id="descriptionHelp" class="form-text">Optional. Max Length: 255</div>
            </div>
            <div class="row mt-3">
                <div class="col-12 d-flex justify-content-center">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save">Save</i>
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

{{/partial}}

{{> common/base}}
