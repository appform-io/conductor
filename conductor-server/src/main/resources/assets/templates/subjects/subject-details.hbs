{{#partial "page_css_includes"}}
    <link href="/css/bootstrap-select.min.css" rel="stylesheet">
{{/partial}}
{{#partial "page_js_includes"}}
    <script type="text/javascript" src="/js/bootstrap-select.min.js"></script>
{{/partial}}
{{#partial "content"}}
    <section>
        <div class="row">
            {{#empty subject}}
                <div class="col-auto"><h4>Register A New Subject</h4></div>
            {{else}}
                <div class="col-auto"><h4>Details for Subject: <b>{{subject.summary.globalId}}</b></h4></div>
            {{/empty}}
        </div>
        <div class="row">
            <div class="col-sm-12 col-md-6">
                <form method="post"
                    {{#empty subject}}
                      action="/subjects/create"
                    {{else}}
                      action="/subjects/{{subject.summary.globalId}}/summary/update"
                    {{/empty}}
                >
                    <div class="md-3">
                        <label for="name" class="col-form-label fw-bold">Name</label>
                        <input type="text" id="name" name="name"
                               class="form-control border border-dark"
                               maxlength="45" placeholder="Subject Name" aria-describedby="nameHelp"
                               value="{{subject.summary.name}}" required>
                        <div id="nameHelp" class="form-text">Name of the subject</div>
                    </div>
                    <div class="row">
                        <div class="col-sm-12 col-md-6">
                            <label for="dob" class="col-form-label fw-bold">Date of birth</label>
                            <input type="date" id="dob" name="dob"
                                   class="form-control border border-dark"
                                   placeholder="Date of birth" aria-describedby="dobHelp"
                                   value="{{htmlDate subject.summary.dob false}}" required>
                            <div id="dobHelp" class="form-text">Date of birth for the subject</div>
                        </div>
                        <div class="col-sm-12 col-md-6">
                            <label for="gender" class="col-form-label fw-bold">Gender</label>
                            <select id="gender" name="gender"
                                    class="form-control selectpicker border border-dark"
                                    aria-describedby="genderHelp" required>
                                <option disabled>Select Gender</option>
                                {{#each gender}}
                                    <option value="{{this}}"
                                            {{#eq this subject.summary.gender}}selected{{/eq}}>{{readable
                                            this}}</option>
                                {{/each}}
                            </select>
                            <div id="genderHelp" class="form-text">Gender for the subject. Select Other if not known.
                            </div>
                        </div>
                    </div>
                    <div class="mb-3 mt-2 d-flex justify-content-center">
                        <button type="submit" class="btn btn-success mb-3"><i class="bi bi-person-fill-check"></i> Save
                        </button>
                    </div>
                </form>
                <section class="m-2">
                    <div class="row">
                        <div class="col-12">
                            <h5>Identities</h5>
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-12">
                            <form method="post" action="/subjects/{{subject.summary.globalId}}/id/add">
                                <div class="row">
                                    <div class="col-sm-12 col-md-4">
                                        <label for="subjectIdType" class="col-form-label fw-bold">Subject ID Type</label>
                                        <select id="subjectIdType" name="subjectIdType"
                                                class="form-control selectpicker border border-dark"
                                                data-live-search="true" aria-describedby="subjectIdTypeHelp" required>
                                            <option disabled>Select ID Type</option>
                                            {{#each subIdTypes}}
                                                <option value="{{this}}">{{displayName}}</option>
                                            {{/each}}
                                        </select>
                                        <div id="subjectIdTypeHelp" class="form-text">Type of ID for the subject</div>
                                    </div>
                                    <div class="col-sm-12 col-md-4">
                                        <label for="subIdSubType" class="col-form-label fw-bold">Sub Type</label>
                                        <input type="text" id="subIdSubType" name="subIdSubType"
                                               class="form-control border border-dark"
                                               aria-describedby="subIdSubTypeHelp"
                                               maxlength="45" placeholder="Subtype (Optional)">
                                        <div id="subIdSubTypeHelp" class="form-text">Sub type in case id is not phone or
                                            email. Max Length: 45
                                        </div>
                                    </div>
                                    <div class="col-sm-12 col-md-4">
                                        <label for="subIdValue" class="col-form-label fw-bold">ID Value</label>
                                        <input type="text" id="subIdValue" name="subIdValue"
                                               class="form-control border border-dark"
                                               maxlength="45" placeholder="Actual value of the ID"
                                               aria-describedby="subIdValueHelp" required>
                                        <div id="subIdValue" class="form-text">Actual value of the ID (eg: Phone Number).
                                            Max Length: 45
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-12 col-md-8">
                                        <label for="verificationStatus" class="col-form-label fw-bold">Verified</label>
                                        <select id="verificationStatus" name="verificationStatus"
                                                class="form-control selectpicker border border-dark"
                                                aria-describedby="verificationStatusHelp">
                                            <option value="UNVERIFIED" selected>No</option>
                                            <option value="MANUALLY_VERIFIED">Manually Verified</option>
                                        </select>
                                        <div id="verificationStatusHelp" class="form-text">Manually verify the ID before selecting yes</div>
                                    </div>
                                    <div class="col-sm-12 col-md-4 text-center justify-content-center">
                                        <button type="submit" class="btn btn-success mt-4"><i class="bi bi-plus"></i> Add</button>
                                    </div>
                                </div>
                            </form>

                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-12 table-responsive">
                            <table class="table table-bordered border-dark">
                                <thead>
                                <tr>
                                    <th>Type</th>
                                    <th>Sub Type</th>
                                    <th>Value</th>
                                    <th class="text-centered">Primary</th>
                                    <th class="text-centered">Verified</th>
                                    <th></th>
                                </tr>
                                </thead>
                                <tbody>
                                {{#each subject.subjectIDs}}
                                    <tr>
                                        <td>{{readable type}}</td>
                                        <td>{{subType}}</td>
                                        <td>{{value}}</td>
                                        <td class="text-center">
                                            {{#eq primary true}}
                                                <span class="badge bg-primary ms-2">Primary</span>
                                            {{else}}
                                                <form method="post"
                                                      action="/subjects/{{subject.summary.globalId}}/id/{{extId}}/primary">
                                                    <button type="submit" class="btn btn-sm btn-outline-primary">Set</button>
                                                </form>
                                            {{/eq}}
                                        </td>
                                        <td class="text-center">
                                            {{#eqEnum verificationStatus "UNVERIFIED"}}
                                                <form method="post"
                                                      action="/subjects/{{subject.summary.globalId}}/id/{{extId}}/verify">
                                                    <button type="submit" class="btn btn-sm btn-outline-primary">Verify</button>
                                                </form>
                                            {{else}}
                                                <span class="badge bg-success ms-2">{{readable verificationStatus}}</span>
                                            {{/eqEnum}}
                                        </td>
                                        <td class="text-center">
                                            <form method="post" class="confirmed-form"
                                                  action="/subjects/{{subject.summary.globalId}}/id/{{extId}}/delete"
                                                  data-cnf-title="Deleting Subject ID"
                                                  data-cnf-text="Are you sure you want to delete this ID?">
                                                <button type="submit" class="btn btn-link p-0 text-danger"
                                                        {{#eq primary true}}disabled{{/eq}}>
                                                    <i class="bi bi-trash-fill"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                {{/each}}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </section>
                <section>
<!--                    TODO::ADDRESS-->
                </section>
            </div>
            <div class="col-sm-12 col-md-6">
                <div class="row mb-2">
                    <div class="col-9 pt-2">
                        <h5>Recent Tickets</h5>
                    </div>
                    <div class="col-3 d-flex justify-content-end">
                        <a role="button" class="btn btn-sm btn-info pt-2"
                           href="/tickets/subject/{{subject.summary.globalId}}">All</a>
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-12 table-responsive">
                        <table class="table table-bordered border-dark">
                            <thead>
                            <tr>
                                <th>Title</th>
                                <th>Type</th>
                                <th>Current State</th>
                                <th>Last updated</th>
                            </tr>
                            </thead>
                            <tbody>
                            {{#each tickets}}
                                <tr>
                                    <td><a href="/tickets/{{ticketId}}/details">{{title}}</a></td>
                                    <td>{{workflowName}}</td>
                                    <td>
                                        <span class="badge {{#eq terminated true}}bg-secondary{{else}}bg-info{{/eq}} ms-2">
                                            {{stateName}}
                                        </span>
                                    </td>
                                    <td>{{updated}}</td>
                                </tr>
                            {{/each}}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </section>
{{/partial}}

{{> common/base}}